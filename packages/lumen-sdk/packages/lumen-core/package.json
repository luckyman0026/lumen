{
  "name": "@lumen/lumen-core",
  "version": "0.1.0",
  "description": "Lumen Core - Framework-agnostic SDK for fire-and-forget AI traffic tracking",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "lumen",
    "observability",
    "analytics",
    "monitoring",
    "fire-and-forget"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumen-org/Lumen.git",
    "directory": "packages/lumen-sdk/packages/lumen-core"
  },
  "homepage": "https://github.com/lumen-org/Lumen#readme",
  "bugs": {
    "url": "https://github.com/lumen-org/Lumen/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
