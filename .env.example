# Lumen Environment Configuration

# API Token for authentication between services
# Generate with: openssl rand -base64 32
INGEST_TOKEN=your-secret-token-here

# ClickHouse Configuration (optional - defaults work for local dev)
# CLICKHOUSE_HOST=clickhouse
# CLICKHOUSE_PORT=9000
# CLICKHOUSE_DB=default
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# Dashboard API Configuration (set these for production)
# API_URL=http://server:8080/v1
# API_KEY=your-secret-token-here
